# Recall Sentinel — Environment Variables
# Copy this file to .env and fill in your values
# NEVER commit .env to GitHub

# Required: Gemini API Key from Google AI Studio
# Get yours at: https://aistudio.google.com/app/apikey
GOOGLE_API_KEY=your_gemini_api_key_here

# Model to use — verify availability on your API key before building
# As of June 2026, gemini-2.5-flash-lite was confirmed working on free tier
GEMINI_MODEL=gemini-2.5-flash-lite

# Optional: logging level (DEBUG, INFO, WARNING, ERROR)
LOG_LEVEL=INFO

# Optional: directory for MCP server state files (do not commit these)
MCP_STATE_DIR=data/
